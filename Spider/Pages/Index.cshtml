@page
@model Spider.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .spider-table th, .spider-table td {
        vertical-align: middle !important;
        padding: 12px 16px !important;
    }

    .path-cell {
        max-width: 280px;
        word-break: break-all;
        white-space: normal;
        font-size: 11px;
        color: #6c757d;
    }

    .service-id {
        font-size: 11px;
        color: #dc3545;
        display: block;
        margin-top: 2px;
    }

    .progress-container {
        width: 110px;
    }

    .btn-action {
        padding: 4px 8px;
        font-size: 12px;
    }

    .container{
        max-width: 1500px !important;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📡 工业级服务监控中心</h2>
    <span class="badge bg-secondary">数据每 5 秒同步</span>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>服务节点信息</th>
                        <th>部署路径</th>
                        <th>内网 IP</th>
                        <th>CPU 占用</th>
                        <th>内存使用</th>
                        <th>当前状态</th>
                        <th>最后活跃</th>
                        <th>管理操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var service in Model.ServicesList)
                    {
                        <tr>
                            <td>
                                <span class="fw-bold d-block text-dark">@service.ServiceName</span>
                                <code style="font-size: 11px;">@service.ServiceId</code>
                            </td>
                            <td><code style="font-size: 11px;">@service.AppFolder</code></td>
                            <td><span class="badge bg-light text-dark border">@service.InternalIp</span></td>
                            <td style="width: 140px;">
                                <small class="text-muted">@service.CpuUsage%</small>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-info" style="width: @service.CpuUsage%"></div>
                                </div>
                            </td>
                            <td><span class="badge bg-dark">@service.MemoryUsageMb MB</span></td>
                            <td>
                                <span class="badge @(service.Status == Models.ServiceStatus.Online ? "bg-success" : service.Status == Models.ServiceStatus.Fault ? "bg-danger" : "bg-secondary")">
                                    @service.Status
                                </span>
                            </td>
                            <td><small>@service.LastSeen.ToString("MM-dd HH:mm:ss")</small></td>
                            <td>
                                <button class="btn btn-sm btn-outline-dark" onclick="openLogModal('@service.ServiceId', '@service.ServiceName')">🔍 实时日志</button>
                                <button class="btn btn-sm btn-outline-danger" onclick="sendControl('@service.ServiceId', 'RESTART', '@service.ServiceName')">🔄 重启</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="logModal" data-bs-backdrop="static" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">🖥️ 控制台: <span id="currentLogServiceName" class="text-info"></span></h5>
                <input type="text" id="logSearchInput" class="form-control form-control-sm w-25 ms-auto me-3 bg-secondary text-white border-0" placeholder="🔍 检索关键字过滤日志...">
                <button type="button" class="btn-close btn-close-white" onclick="closeLogModal()"></button>
            </div>
            <div class="modal-body" style="background-color: #121212; min-height: 480px;">
                <div id="logTerminal" style="font-family: monospace; font-size: 13px;"></div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

<script>
    let pageRefreshTimer = setTimeout(() => window.location.reload(), 5000);
    let currentServiceId = "";
    let rawLogCache = []; // 本地日志完整缓存，供检索使用
    let logModalEntity = new bootstrap.Modal(document.getElementById('logModal'));

    const connection = new signalR.HubConnectionBuilder().withUrl("/hub/logs").withAutomaticReconnect().build();
    connection.start();

    connection.on("ReceiveLog", function (logLine) {
    rawLogCache.push(logLine);
    renderLogLine(logLine);
    });

    function renderLogLine(logLine) {
    const filterText = document.getElementById("logSearchInput").value.toLowerCase();
    if (filterText && !logLine.toLowerCase().includes(filterText)) return; // 被过滤则不渲染

    const terminal = document.getElementById("logTerminal");
    let color = "#ffffff";
    if (logLine.includes("[Error]") || logLine.includes("Exception")) color = "#ff6b6b";
    else if (logLine.includes("[Warning]")) color = "#ffd257";

    terminal.innerHTML += `<div style="color: ${color}; border-bottom: 1px solid #1f1f1f; padding: 2px 0;">${logLine}</div>`;
    document.querySelector(".modal-body").scrollTop = document.querySelector(".modal-body").scrollHeight;
    }

    // 监听键盘输入，实时过滤历史日志
    document.getElementById("logSearchInput").addEventListener("input", function() {
    document.getElementById("logTerminal").innerHTML = "";
    rawLogCache.forEach(line => renderLogLine(line));
    });

    function openLogModal(serviceId, serviceName) {
    clearTimeout(pageRefreshTimer);
    currentServiceId = serviceId;
    rawLogCache = [];
    document.getElementById("logSearchInput").value = "";
    document.getElementById("currentLogServiceName").innerText = serviceName;
    document.getElementById("logTerminal").innerHTML = "";
    logModalEntity.show();
    connection.invoke("JoinServiceGroup", currentServiceId);
    }

    function closeLogModal() {
    logModalEntity.hide();
    connection.invoke("LeaveServiceGroup", currentServiceId);
    pageRefreshTimer = setTimeout(() => window.location.reload(), 5000);
    }

    function sendControl(serviceId, command, serviceName) {
        if (confirm(`确定要对服务【${serviceName}】执行远程 [${command}] 操作吗？`)) {
            if (connection.state === signalR.HubConnectionState.Connected) {
            connection.invoke("SendControlCommand", serviceId, command)
            .then(() => alert(`指令 [${command}] 已下发，系统将通过守护进程自动重启，请静候看板刷新。`))
            .catch(err => alert("指令下发失败: " + err));
            } else {
            alert("SignalR 连接已断开，无法下发指令。");
            }
        }
    }
</script>